# TimescaleDB
POSTGRES_USER=mm
POSTGRES_PASSWORD=mm
POSTGRES_DB=mm_monitoring
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Convenient single-URL form used by ingestor/sla/dashboard
DATABASE_URL=postgres://mm:mm@localhost:5432/mm_monitoring

# Hyperliquid
HL_WS_URL=wss://api.hyperliquid.xyz/ws
HL_INFO_URL=https://api.hyperliquid.xyz/info

# Comma-separated Hyperliquid markets to monitor. Each entry is the exact
# identifier Hyperliquid uses (the same string the UI shows and the WS
# `coin` field expects). The kind of market is inferred from the shape:
#
#   plain alnum, e.g. BTC, SOL, HYPE          -> default USDC perp dex
#   contains "/" or starts with "@"           -> spot pair
#     e.g. BASED/USDC, PURR/USDC, @1
#   contains "-", e.g. BASED-USDE              -> alt-dex perp; venue tag is
#                                                derived from the suffix
#
# The venue column in the database becomes:
#   hyperliquid_perp             (default USDC perps)
#   hyperliquid_spot             (spot pairs)
#   hyperliquid_perp_<suffix>    (alt-dex perps, e.g. hyperliquid_perp_usde)
HL_MARKETS=BTC,SOL

# Legacy alias kept for one release; if HL_MARKETS is set, this is ignored.
# HL_SYMBOLS=BTC,SOL

# Comma-separated MM addresses to track via orderUpdates (lowercase hex with 0x)
# Leave empty to skip per-MM attribution and only collect aggregate book data.
HL_TRACKED_ADDRESSES=

# Health thresholds
HEALTH_STALE_MS=2000

# Bucketing
METRIC_BUCKET_MS=100

# Depth distances to compute (basis points from mid, comma-separated)
DEPTH_BPS=5,10,25
